generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// BETTER AUTH TABLES
// ─────────────────────────────────────────────

model user {
  id               String    @id
  name             String
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  image            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  username         String?   @unique
  displayUsername  String?

  role             String    @default("applicant")
  twoFactorEnabled Boolean   @default(false)

  sessions         session[]
  accounts         account[]
  twoFactors       twoFactor[]

  admissionId      Int?      @unique
  admission        Admission? @relation(fields: [admissionId], references: [id])
  studentId        String?   @unique
  student          Student?  @relation(fields: [studentId], references: [id])

  @@map("user")
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?  @db.Text
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
  @@map("verification")
}

model twoFactor {
  id          String @id
  secret      String @db.Text
  backupCodes String @db.Text
  userId      String @unique
  user        user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

// ─────────────────────────────────────────────
// BUSINESS TABLES
// ─────────────────────────────────────────────

model Admission {
  id Int @id @default(autoincrement())

  nameEn               String
  nameBn               String?
  nameAr               String?
  dob                  DateTime?
  birthCertificateNo   String?
  gender               String
  height               String?
  weight               String?
  nationality          String?
  bloodGroup           String?
  identifySign         String?

  presentVillage       String?
  presentPost          String?
  presentUpazilla      String?
  presentPostCode      String?
  presentZilla         String?

  permanentVillage     String?
  permanentPost        String?
  permanentUpazilla    String?
  permanentZilla       String?
  permanentPostCode    String?

  fatherNameEn         String?
  fatherNameBn         String?
  fatherEducation      String?
  fatherOccupation     String?
  fatherMonthlyEarning String?
  fatherMobileNo       String?
  fatherNidNo          String?
  fatherDob            DateTime?

  motherNameEn         String?
  motherNameBn         String?
  motherEducation      String?
  motherOccupation     String?
  motherMonthlyEarning String?
  motherMobileNo       String?
  motherNidNo          String?
  motherDob            DateTime?

  guardianName             String?
  guardianRelation         String?
  guardianPresentAddress   String?
  guardianPermanentAddress String?
  guardianEducation        String?
  guardianOccupation       String?
  guardianMonthlyEarning   String?
  guardianMobileNo         String?
  guardianNidNo            String?
  guardianDob              DateTime?

  className             String
  sessionName           String?
  division              String?
  previousInstituteName String?
  siblingDetails        String?

  // Pending | Under Review | Awaiting Test | Approved | Enrolled | Rejected
  status            String  @default("Pending")
  // Unpaid | Payment Submitted | Paid | Fake Payment Proof
  paymentStatus     String  @default("Unpaid")
  applicationFee    Decimal @default(0) @db.Decimal(10, 2)
  paymentTrackingId String?

  // Enrollment fee (separate from application fee)
  // Unpaid | Payment Submitted | Paid
  enrollmentPaymentStatus     String  @default("Unpaid")
  enrollmentPaymentTrackingId String?

  studentPhoto      String?
  studentSignature  String?

  adminNote  String?   @db.Text
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admissionConfigId Int?
  admissionConfig   AdmissionConfig? @relation(fields: [admissionConfigId], references: [id])
  mark              AdmissionMark?

  user               user?
  paymentSubmissions PaymentSubmission[]
  student            Student?
}

model Student {
  id          String    @id
  admissionId Int       @unique
  admission   Admission @relation(fields: [admissionId], references: [id])

  className    String
  section      String?
  rollNumber   String?
  academicYear String
  sessionName  String?

  // Active | Inactive | Graduated | Transferred
  status String @default("Active")

  enrolledAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user               user?
  bills              Bill[]
  receipts           Receipt[]
  results            ExamResult[]
  paymentSubmissions PaymentSubmission[]
  yearEndResults     YearEndResult[]
  promotionRecords   PromotionRecord[]
}

model FeeConfig {
  id               String  @id
  name             String
  amount           Decimal @db.Decimal(10, 2)
  // monthly | quarterly | yearly | one_time
  type             String
  applicableClasses Json
  dueDay           Int?
  lateFee          Decimal? @db.Decimal(10, 2)
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills Bill[]
}

model Bill {
  id          String    @id
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  feeConfigId String
  feeConfig   FeeConfig @relation(fields: [feeConfigId], references: [id])

  amount       Decimal @db.Decimal(10, 2)
  lateFee      Decimal @default(0) @db.Decimal(10, 2)
  dueDate      DateTime
  month        String?
  academicYear String
  // unpaid | partial | paid | waived
  status String @default("unpaid")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receiptItems       ReceiptItem[]
  paymentSubmissions PaymentSubmission[]
}

model Receipt {
  id        String  @id
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  receiptNumber  String   @unique
  // cash | bank_transfer | cheque | online
  paymentMethod  String
  receivedAmount Decimal  @db.Decimal(10, 2)
  paymentDate    DateTime
  createdBy      String

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ReceiptItem[]
}

model ReceiptItem {
  id        String  @id
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  billId    String
  bill      Bill    @relation(fields: [billId], references: [id])
  amount    Decimal @db.Decimal(10, 2)
}

model PaymentSubmission {
  id String @id

  admissionId Int?
  admission   Admission? @relation(fields: [admissionId], references: [id])
  studentId   String?
  student     Student?   @relation(fields: [studentId], references: [id])
  billId      String?
  bill        Bill?      @relation(fields: [billId], references: [id])

  // admission | enrollment | exam_fee
  paymentContext String
  // bkash | rocket | bank_transfer
  method        String
  transactionId String
  phoneNumber   String?
  amountSent    Decimal  @db.Decimal(10, 2)
  paymentDate   DateTime
  notes         String?  @db.Text
  screenshotUrl String?

  accountHolderName String?
  branch            String?
  depositSlipNo     String?

  // pending | under_review | verified | rejected
  status        String    @default("pending")
  adminNote     String?   @db.Text
  verifiedBy    String?
  verifiedAt    DateTime?
  receiptNumber String?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExamResult {
  id        String  @id
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  examName     String
  academicYear String
  // [{ subject, fullMarks, obtainedMarks, grade }]
  subjects Json

  totalMarks  Decimal? @db.Decimal(10, 2)
  gpa         Decimal? @db.Decimal(4, 2)
  grade       String?
  position    Int?
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SCHOOL CLASSES
// ─────────────────────────────────────────────

model SchoolClass {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ADMISSION CONFIG
// ─────────────────────────────────────────────

model AdmissionConfig {
  id           Int     @id @default(autoincrement())
  academicYear String  // e.g. "2026"
  isActive     Boolean @default(false)

  applicationStartDate DateTime?
  applicationEndDate   DateTime?

  // "same_for_all" | "per_class"
  feeMode    String          @default("same_for_all")
  globalFee  Decimal?        @db.Decimal(10, 2)

  globalTestDay         DateTime?
  globalTestType        String?   // "written" | "viva" | "both"
  globalMaxWrittenMarks Float?
  globalMaxVivaMarks    Float?

  resultDay        DateTime?
  // "real_time" | "result_day"
  resultVisibility String    @default("real_time")

  marksThresholdEnabled Boolean @default(false)
  marksPassThreshold    Float?
  // "auto_enroll" | "flag_review"
  marksThresholdAction  String  @default("flag_review")

  // Enrollment fee (paid after approval, before student account is created)
  // "same_for_all" | "per_class"
  enrollmentFeeMode     String   @default("same_for_all")
  enrollmentFeeRequired Boolean  @default(false)
  enrollmentFeeAmount   Decimal? @db.Decimal(10, 2)

  classConfigs ClassAdmissionConfig[]
  admissions   Admission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClassAdmissionConfig {
  id                Int             @id @default(autoincrement())
  admissionConfigId Int
  admissionConfig   AdmissionConfig @relation(fields: [admissionConfigId], references: [id], onDelete: Cascade)

  // matches Admission.className
  className String

  fee                 Decimal? @db.Decimal(10, 2)
  enrollmentFeeAmount Decimal? @db.Decimal(10, 2)
  testDay             DateTime?
  testType            String?   // "written" | "viva" | "both"
  maxWrittenMarks     Float?
  maxVivaMarks        Float?
  resultDay           DateTime?
}

model AdmissionMark {
  id          Int       @id @default(autoincrement())
  admissionId Int       @unique
  admission   Admission @relation(fields: [admissionId], references: [id])

  writtenMarks Float?
  vivaMarks    Float?
  totalMarks   Float?
  enteredBy    String?
  enteredAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SMS
// ─────────────────────────────────────────────

model SmsConfig {
  id       Int     @id @default(1)
  apiKey   String?
  senderId String?

  applicationReceived Boolean @default(true)
  paymentStatus       Boolean @default(true)
  testDayReminder     Boolean @default(false)
  resultRealTime      Boolean @default(false)
  resultSixHourBefore Boolean @default(false)
  resultAtTime        Boolean @default(true)
  resultSixHourAfter  Boolean @default(false)
}

model SmsLog {
  id          String  @id @default(cuid())
  admissionId Int?
  phone       String
  // "application_received" | "payment_status" | "test_day" | "result"
  type        String
  message     String  @db.Text
  // "sent" | "failed"
  status      String  @default("sent")
  error       String? @db.Text
  sentAt      DateTime @default(now())
}

// ─────────────────────────────────────────────
// School Settings (singleton, id = 1)
// ─────────────────────────────────────────────

model SchoolSetting {
  id          Int    @id @default(1)
  name        String @default("School Name")
  address     String @default("")
  city        String @default("")
  phone       String @default("")
  email       String @default("")
  website     String @default("")
  eiin        String @default("")
  established String @default("")
}

// ─────────────────────────────────────────────
// ACTIVITY LOG
// ─────────────────────────────────────────────

model ActivityLog {
  id          Int      @id @default(autoincrement())
  // admission | student | payment | fee | exam | result | system
  module      String
  action      String
  entityType  String
  entityId    String
  entityLabel String?
  actorId     String?
  actorName   String?
  actorRole   String   @default("system")
  description String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([module])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// YEAR-END RESULTS & PROMOTION HISTORY
// ─────────────────────────────────────────────

model YearEndResult {
  id           String  @id
  studentId    String
  student      Student @relation(fields: [studentId], references: [id])

  academicYear String
  // Pass | Fail | Supplementary
  result       String
  nextClass    String?
  notes        String?   @db.Text
  decidedBy    String?
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, academicYear])
}

model PromotionRecord {
  id               String  @id
  studentId        String
  student          Student @relation(fields: [studentId], references: [id])

  fromClass        String
  fromAcademicYear String
  toClass          String
  toAcademicYear   String
  // Pass | Fail | Supplementary
  result           String
  createdBy        String?
  notes            String? @db.Text

  createdAt DateTime @default(now())
}
