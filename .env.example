# .env.example — copy to .env.local and fill in values

# ── Next.js App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (shared secret for both Better Auth and student JWT) ────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=rand-key-securiry

# ── Laravel API ───────────────────────────────────────────────────────────────
# Used by lib/auth/student.ts server action (full base URL, no /api suffix)
API_URL=https://apiurl.com

# Used by client-side api.ts fetch calls (includes /api suffix)
NEXT_PUBLIC_API_URL=https://apiurl.com/api

# Multi-tenant domain header sent with every API request
NEXT_PUBLIC_TENANT_DOMAIN=school1.com

# ── Auth Endpoints (for reference) ───────────────────────────────────────────
# Staff login  → POST {API_URL}/api/auth/login       { email, password }
# Student login→ POST {API_URL}/api/admission/login  { username, password }
# Apply        → POST {API_URL}/api/admission        (form fields as body)
